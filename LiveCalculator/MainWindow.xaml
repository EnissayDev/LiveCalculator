<Window x:Class="LiveCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LiveCalculator"
        xmlns:ctrl="clr-namespace:LiveCalculator.Controls"
        mc:Ignorable="d"
        Title="LiveCalculator — SR / PP"
        Height="720" Width="470"
        MinHeight="620" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#171A1C"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9CA3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DBE9F0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Connection status -->
        <Border Grid.Row="0" CornerRadius="10" Padding="12,6" HorizontalAlignment="Center" Background="#2E3538">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#ED1121" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Fill" Value="#88B300" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionStatus}" Foreground="#DBE9F0" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Beatmap header -->
        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Text="{Binding Title}" Foreground="#FFFFFF" FontSize="21" FontWeight="Bold"
                       TextAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Artist}" Foreground="#8F9CA3" FontSize="13"
                       TextAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock Text="{Binding Version}" Foreground="#FF66AA" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding Mapper}" Foreground="#5C6970" FontSize="12" />
            </StackPanel>
        </StackPanel>

        <!-- Live readout -->
        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <!-- Star rating pill (osu! style: spectrum background, SR-coloured icon + text) -->
            <Border CornerRadius="100" Padding="16,6" HorizontalAlignment="Center" Background="{Binding StarBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="★" Foreground="{Binding StarTextBrush}" FontSize="17" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock Text="{Binding CurrentStarsText}" Foreground="{Binding StarTextBrush}" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Big PP -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <TextBlock Text="{Binding PpText}" Foreground="#FFFFFF" FontSize="66" FontWeight="Bold" />
                <TextBlock Text="pp" Foreground="#FF66AA" FontSize="26" FontWeight="Bold" VerticalAlignment="Bottom" Margin="6,0,0,12" />
            </StackPanel>
        </StackPanel>

        <!-- Stat row -->
        <Border Grid.Row="3" CornerRadius="10" Background="#22282A" Padding="14,12" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="MAX SR" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding MaxStarsText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ACCURACY" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding AccuracyText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="COMBO" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding ComboText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="MODS" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding ModsText}" Style="{StaticResource Value}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Skills breakdown -->
        <Border Grid.Row="4" CornerRadius="10" Background="#22282A" Padding="14,12" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="STRAIN" Foreground="#8F9CA3" FontSize="11" FontWeight="SemiBold" />

                <!-- Auto-discovered skill legend (osu! style chips) -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding SkillLegend}" Margin="0,8,0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2E3538" CornerRadius="10" Padding="9,4" Margin="0,0,7,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Fill="{Binding Brush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding Brush}" FontSize="12" FontWeight="SemiBold" Margin="6,0,5,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ValueText}" Foreground="#8F9CA3" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Graph -->
                <Border Grid.Row="2" CornerRadius="8" Background="#171A1C" MinHeight="130">
                    <Grid>
                        <ctrl:SkillGraph Series="{Binding Skills}" Margin="6" />
                        <TextBlock Text="Strain breakdown appears while a beatmap is loaded"
                                   Foreground="#5C6970" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSkills}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Diagnostics -->
        <TextBlock Grid.Row="5" Text="{Binding Diagnostics}" Foreground="#5C6970" FontSize="10.5"
                   TextWrapping="Wrap" Margin="2,10,2,0" />
    </Grid>
</Window>
