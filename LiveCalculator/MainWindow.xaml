<Window x:Class="LiveCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LiveCalculator"
        xmlns:ctrl="clr-namespace:LiveCalculator.Controls"
        mc:Ignorable="d"
        Title="Enissay Rework | Calc"
        Height="880" Width="470"
        MinHeight="760" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#171A1C"
        FontFamily="pack://application:,,,/Assets/Fonts/#Poppins, Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F9CA3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DBE9F0" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <!-- Small pill button used for the compact-mode toggle -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="#DBE9F0" />
            <Setter Property="Background" Value="#2E3538" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="9" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A4245" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar: connection status (full mode) + compact toggle -->
        <Grid Grid.Row="0">
            <!-- Connection status -->
            <Border CornerRadius="10" Padding="12,6" HorizontalAlignment="Center" Background="#2E3538"
                    Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#ED1121" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#88B300" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="#DBE9F0" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Compact-mode toggle (always visible) -->
            <Button x:Name="CompactButton" Style="{StaticResource PillButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center" Click="CompactToggle_Click">
                <Button.Content>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="▁ Compact" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CompactMode}" Value="True">
                                        <Setter Property="Text" Value="▢ Expand" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Button.Content>
            </Button>
        </Grid>

        <!-- Beatmap header (full mode only) -->
        <StackPanel Grid.Row="1" Margin="0,18,0,0"
                    Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding Title}" Foreground="#FFFFFF" FontSize="21" FontWeight="Bold"
                       TextAlignment="Center" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Artist}" Foreground="#8F9CA3" FontSize="13"
                       TextAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                <TextBlock Text="{Binding Version}" Foreground="#FF66AA" FontSize="12" FontWeight="SemiBold" Margin="0,0,8,0" />
                <TextBlock Text="{Binding Mapper}" Foreground="#5C6970" FontSize="12" />
            </StackPanel>
        </StackPanel>

        <!-- Live readout -->
        <StackPanel Grid.Row="2" Margin="0,18,0,0">
            <!-- Pre-rework comparison: mini old-SR pill + delta + verdict (official SR + delta) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10"
                        Visibility="{Binding HasDelta, Converter={StaticResource BoolToVisibility}}">
                <Border CornerRadius="4" Padding="9,3" VerticalAlignment="Center" Background="{Binding OldStarBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="★" Foreground="{Binding OldStarTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding OldStarsText}" Foreground="{Binding OldStarTextBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <TextBlock Text="pre-rework" Foreground="#8F9CA3" FontSize="11" VerticalAlignment="Center" Margin="7,0,0,0" />
                <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
                <TextBlock Text="{Binding ConclusionText}" Foreground="{Binding ConclusionBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>

            <!-- Star rating pill (new rework SR) + live gameplay SR -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border CornerRadius="6" Padding="16,6" VerticalAlignment="Center" Background="{Binding StarBrush}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="★" Foreground="{Binding StarTextBrush}" FontSize="17" VerticalAlignment="Center" Margin="0,0,7,0" />
                        <TextBlock Text="{Binding CurrentStarsText}" Foreground="{Binding StarTextBrush}" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding LiveSrText}" Foreground="#8F9CA3" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="9,0,0,0" />
            </StackPanel>

            <!-- Big PP — current / max (full mode only) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0"
                        Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding PpText}" Foreground="#FFFFFF" FontSize="50" FontWeight="Bold" />
                <TextBlock Text="pp" Foreground="#FF66AA" FontSize="22" FontWeight="Bold" VerticalAlignment="Bottom" Margin="6,0,0,9" />
            </StackPanel>

            <!-- Compact PP — current / max (compact mode only) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0"
                        Visibility="{Binding CompactMode, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding PpText}" Foreground="#FFFFFF" FontSize="22" FontWeight="Bold" />
                <TextBlock Text="pp" Foreground="#FF66AA" FontSize="13" FontWeight="Bold" VerticalAlignment="Bottom" Margin="4,0,0,3" />
            </StackPanel>
        </StackPanel>

        <!-- Stat row (full mode only) -->
        <Border Grid.Row="3" CornerRadius="10" Background="#22282A" Padding="14,12" Margin="0,14,0,0"
                Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="OFFICIAL SR" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding OfficialSrText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="ACCURACY" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding AccuracyText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="COMBO" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding ComboText}" Style="{StaticResource Value}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="MODS" Style="{StaticResource Label}" />
                    <TextBlock Text="{Binding ModsText}" Style="{StaticResource Value}" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Skills breakdown (full mode only) -->
        <Border Grid.Row="4" CornerRadius="10" Background="#22282A" Padding="14,12" Margin="0,14,0,0"
                Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="STRAIN" Foreground="#8F9CA3" FontSize="11" FontWeight="SemiBold" />

                <!-- Auto-discovered skill legend (osu! style chips) -->
                <ItemsControl Grid.Row="1" ItemsSource="{Binding SkillLegend}" Margin="0,8,0,8">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2E3538" CornerRadius="10" Padding="9,4" Margin="0,0,7,6">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Ellipse Width="9" Height="9" Fill="{Binding Brush}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding Brush}" FontSize="12" FontWeight="SemiBold" Margin="6,0,5,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ValueText}" Foreground="#8F9CA3" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Graph -->
                <Border Grid.Row="2" CornerRadius="8" Background="#171A1C" MinHeight="130">
                    <Grid>
                        <ctrl:SkillGraph Series="{Binding Skills}" Margin="6" />
                        <TextBlock Text="Strain breakdown appears while a beatmap is loaded"
                                   Foreground="#5C6970" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSkills}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Diagnostics (full mode only) -->
        <TextBlock Grid.Row="5" Text="{Binding Diagnostics}" Foreground="#5C6970" FontSize="10.5"
                   TextWrapping="Wrap" Margin="2,10,2,0"
                   Visibility="{Binding FullMode, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</Window>
